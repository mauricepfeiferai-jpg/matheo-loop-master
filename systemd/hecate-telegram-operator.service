[Unit]
Description=HECATE Telegram Operator — persoenlicher Assistent fuer Maurice
After=network-online.target ollama.service
Wants=network-online.target ollama.service

[Service]
Type=simple
ExecStart=/usr/bin/python3 -m hecate.telegram_operator
WorkingDirectory=/root/projects/loop-master
Restart=always
RestartSec=10
StandardOutput=append:/var/log/hecate-telegram-operator.log
StandardError=append:/var/log/hecate-telegram-operator.log
Environment="PYTHONPATH=/root/projects/loop-master"

[Install]
WantedBy=multi-user.target
